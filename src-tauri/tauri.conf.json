{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SHIT VAULT",
  "version": "0.1.0",
  "identifier": "com.dave.shitvault",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "SHIT VAULT",
        "label": "main",
        "width": 455,
        "height": 660,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true
      }
    ]
  }
}

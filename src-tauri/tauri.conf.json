{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SHIT VAULT",
  "version": "1.1.0",
  "identifier": "com.dave.shitvault",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "publisher": "Dave",
    "category": "Utility",
    "shortDescription": "Windows tray-first utility shell for SHIT VAULT modules.",
    "longDescription": "SHIT VAULT is a Windows tray-first desktop app with native prevent-sleep and auto-mixing modules.",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis/installer-hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "SHIT VAULT",
        "label": "main",
        "width": 455,
        "height": 660,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true
      }
    ]
  }
}

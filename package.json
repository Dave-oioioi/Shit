{
  "name": "shit-vault",
  "private": true,
  "description": "Windows tray-first utility shell for auto mixing, prevent sleep, and small native tools.",
  "version": "1.1.0",
  "homepage": "https://dave-oioioi.github.io/SHIT/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dave-oioioi/SHIT.git"
  },
  "author": "Dave",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "npm test && npm run build && cargo check --manifest-path src-tauri/Cargo.toml && git diff --check",
    "check:release": "npm run check && npm run tauri:build-exe && npm run tauri:build",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build-exe": "tauri build --no-bundle"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "lucide-react": "^0.525.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vitest": "^2.1.5"
  }
}
